# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Git and IDE
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo

# Environment (mount or pass at runtime)
.env
.env.*
!.env.example

# Build outputs (frontend/dist is copied in – build with npm run build -w frontend first)
dist/
build/

# Logs and cache
*.log
npm-debug.log*
.cache/
.temp/

# OS
.DS_Store
Thumbs.db

# Docs and misc (optional: remove if you want them in image)
*.md
!README.md

# Tests (optional)
**/__tests__/
**/*.test.js
**/*.spec.js
